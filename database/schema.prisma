datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

generator server_client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  ADMIN
  STAFF
}

enum ClientStatus {
  ACTIVE
  PENDING
  EXPIRED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(ADMIN)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  histories History[]

  @@map("users")
}

model Sector {
  id            String   @id @default(uuid())
  name          String   @unique
  totalCapacity Int      @map("total_capacity")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  clients       Client[]

  @@map("sectors")
}

model Client {
  id              String       @id @default(uuid())
  fullName        String       @map("full_name") // Nombres y Apellidos del difunto
  contactName     String       @default("") @map("contact_name") // Nombre del contacto
  dni             String       @unique
  phone           String?
  address         String?      // Ubicación
  flowers         String       @default("") // Flores
  amount          Float        @default(0.0) // Monto
  remarks         String?      @db.Text
  status          ClientStatus @default(ACTIVE)
  lastPaymentDate DateTime?    @map("last_payment_date") // Fecha de inicio
  nextDueDate     DateTime?    @map("next_due_date")     // Fecha de vencimiento
  sectorId        String?      @map("sector_id")
  sector          Sector?      @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  payments        Payment[]
  histories       History[]

  @@map("clients")
}

model Payment {
  id            String        @id @default(uuid())
  clientId      String        @map("client_id")
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount        Float
  paymentDate   DateTime      @default(now()) @map("payment_date")
  dueDateFrom   DateTime      @map("due_date_from")
  dueDateTo     DateTime      @map("due_date_to")
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  remarks       String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model History {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientId  String?  @map("client_id")
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  action    String
  details   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("histories")
}
