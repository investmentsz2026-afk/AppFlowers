{
  "$schema": "https://vercel.com/static/schema.json",
  "version": 2,
  "builds": [
    {
      "src": "apps/web/next.config.js",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://<YOUR_RENDER_BACKEND_URL>/api/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/apps/web/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://<YOUR_RENDER_BACKEND_URL>/api"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/apps/web/$1" }
  ]
}
